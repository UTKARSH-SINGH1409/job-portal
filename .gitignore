# Root .gitignore for JOB_PORTAL_PROJECT
# Combines common Node/Vite + Java/Spring + IDE + OS + sensitive file patterns

### Node / Frontend ###
node_modules/
frontend/node_modules/
dist/
dist-ssr/
frontend/dist/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
*.local

### Vite / dev ###
.vite/

### Java / Spring Boot ###
job-portal-spring-boot/target/
target/
!**/src/main/**/target/
!**/src/test/**/target/
.mvn/wrapper/maven-wrapper.jar

### IDE / Editor ###
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.classpath
.project

### OS files ###
.DS_Store
Thumbs.db

### Logs & build outputs ###
logs/
*.log
*.jar

### Sensitive / secret files ###
# Environment files (frontend and backend)
.env
.env.*
frontend/.env
job-portal-spring-boot/.env

# Spring Boot config (local secret configs)
**/application.properties
**/application-*.properties
**/application.yml
**/application-*.yml

# Keys, certs, keystores
*.jks
*.keystore
*.p12
*.pem
*.key
*.crt

# Common secret folders
secrets/
credentials/
config/secrets.yml

### Misc ###
local.properties

